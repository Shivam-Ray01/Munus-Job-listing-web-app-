<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Munus — Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/style/loginpage.css">
</head>
<body>

    <!-- Left panel -->
    <div class="left-panel">
        <div class="left-bg"></div>
        <div class="left-overlay"></div>
        <div class="left-content">
            <a href="/" class="left-logo">Munus</a>
            <div class="left-bottom">
                <h2>Welcome<br>back.</h2>
                <p>Your next opportunity is waiting. Sign in to continue your journey.</p>
            </div>
        </div>
    </div>

    <!-- Right panel -->
    <div class="right-panel">
        <div class="form-tag">Sign in</div>
        <h1 class="form-title">Login to Munus</h1>
        <p class="form-sub">Don't have an account? <a href="/register">Create one →</a></p>

        <form action="/login" method="post">
            <div class="input-group">
                <label class="input-label">Email address</label>
                <div class="input-wrap">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="email" class="input-field" placeholder="you@email.com" required>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">Password</label>
                <div class="input-wrap">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="password" class="input-field" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="submit-btn">Sign in →</button>
        </form>

        <div class="divider"><span>or</span></div>

        <a href="/" class="back-home">
            <i class="fas fa-arrow-left" style="font-size: 10px;"></i> Back to home
        </a>
    </div>

</body>
</html>
