<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Munus — Applications</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/style/munus.css">
</head>
<body>

    <nav>
        <a href="/" class="nav-logo">Munus</a>
        <div class="nav-right">
            <a href="/dashboard" class="nav-btn btn-ghost"><i class="fas fa-arrow-left"></i> Dashboard</a>
            <a href="/logout" class="nav-btn btn-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <main>
        <!-- Job info header -->
        <div class="card" style="margin-bottom: 1.5rem;">
            <div class="page-tag">Applications for</div>
            <h1 style="font-family: Syne, sans-serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.3px;">
                <%= job.jobtitle %>
            </h1>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.2rem;"><%= job.companyname %></p>
            <div class="meta-row">
                <div class="meta-item"><i class="fas fa-users"></i> <%= forms.length %> application<%= forms.length !== 1 ? 's' : '' %> received</div>
            </div>
        </div>

        <% if (forms.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-inbox"></i></div>
                <p>No applications received yet for this job.</p>
            </div>
        <% } else { %>
            <div class="grid-1">
                <% forms.forEach(form => { %>
                    <div class="card card-accent">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                            <div style="display: flex; align-items: center; gap: 0.75rem;">
                                <div style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--purple)); display: flex; align-items: center; justify-content: center; font-family: Syne, sans-serif; font-weight: 700; font-size: 1rem; flex-shrink: 0;">
                                    <%= form.name.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <p style="font-family: Syne, sans-serif; font-weight: 700; font-size: 1rem;">Name - <%= form.name %></p>
                                    <p style="font-size: 0.82rem; color: var(--text-muted);">E-mail - <%= form.email %></p>
                                </div>
                            </div>
                            <span class="badge <%= form.status === 'accepted' ? 'badge-green' : form.status === 'rejected' ? 'badge-red' : 'badge-yellow' %>">
                                <%= form.status %>
                            </span>
                        </div>

                        <div class="meta-row">
                            <div class="meta-item">
                                <i class="fas fa-clock"></i>
                                Available immediately: <%= form.availability %>
                            </div>
                            <div class="meta-item">
                                <i class="fas fa-calendar"></i>
                                Applied <%= new Date(form.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </div>
                        </div>

                        <div class="action-row">
                            <a href="/resume/<%= form.resume %>" class="nav-btn btn-ghost" target="_blank">
                                <i class="fas fa-file-pdf"></i> View Resume
                            </a>

                            <form action="/application/accept/<%= form._id %>" method="post" style="display:inline;">
                                <button type="submit" class="nav-btn btn-success">
                                    <i class="fas fa-check"></i> Accept
                                </button>
                            </form>

                            <form action="/application/reject/<%= form._id %>" method="post" style="display:inline;">
                                <button type="submit" class="nav-btn btn-danger">
                                    <i class="fas fa-times"></i> Reject
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

</body>
</html>
