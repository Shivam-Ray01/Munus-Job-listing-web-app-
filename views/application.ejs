<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applications</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen p-10">

    <div class="mb-8">
        <h1 class="text-3xl font-bold"><%= job.jobtitle %></h1>
        <p class="text-gray-400"><%= job.companyname %></p>
    </div>

    <% if (forms.length === 0) { %>
        <div class="bg-gray-800 p-6 rounded-xl text-center text-gray-400 border border-gray-700">
            <p>No applications yet for this job.</p>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 gap-4">
            <% forms.forEach(form => { %>
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
                    
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-xl font-bold">Name - <%= form.name %></h3>
                            <p class="text-gray-400">E-mail - <%= form.email %></p>
                        </div>
                    <span class="px-3 py-1 rounded-full text-sm
                           <%= form.status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' : 
                              form.status === 'accepted' ? 'bg-green-500/20 text-green-400' : 
                             'bg-red-500/20 text-red-400' %>">
                           <%= form.status %>
                    </span>
                </div>

                    <div class="mt-3 text-sm text-gray-400">
                        <p>Available to join immediately: <%= form.availability %></p>
                    </div>

                    <div class="mt-4 flex gap-3">
                        <a href="/resume/<%= form.resume %>"
                           class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-lg text-sm hover:bg-blue-500/40">
                            View Resume
                        </a>

                        <form action="/application/accept/<%= form._id %>" method="post">
                            <button type="submit"
                                class="bg-green-500/20 text-green-400 px-3 py-1 rounded-lg text-sm hover:bg-green-500/40">
                                Accept
                            </button>
                        </form>

                        <form action="/application/reject/<%= form._id %>" method="post">
                            <button type="submit"
                                class="bg-red-500/20 text-red-400 px-3 py-1 rounded-lg text-sm hover:bg-red-500/40">
                                Reject
                            </button>
                        </form>
                    </div>

                </div>
            <% }) %>
        </div>
    <% } %>

</body>
</html>