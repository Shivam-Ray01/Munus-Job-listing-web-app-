<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen p-10">

    <!-- Profile Info -->
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 mb-8">
        <h1 class="text-3xl font-bold mb-2"><%= loggedInUsers.username %></h1>
        <p class="text-gray-400"><%= loggedInUsers.email %></p>
        <span class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full text-sm mt-2 inline-block">
            <%= loggedInUsers.role %>
        </span>
       <% if (loggedInUsers.role === 'recruiter') { %>  
             <a href="/dashboard" class="bg-gray-700 px-4 py-2 rounded-lg hover:bg-gray-600"> Back</a>
         <% }  else { %>
        <a href="/jobs" class="bg-gray-700 px-4 py-2 rounded-lg hover:bg-gray-600"> Back</a>
         <% } %>
        <a href="/logout" class="bg-red-500/20 text-red-400 px-4 py-2 rounded-lg">Logout</a>
    </div>

    <% if (loggedInUsers.role === 'recruiter') { %>
        <h2 class="text-xl font-semibold mb-4">Your Posted Jobs</h2>
        <% if (jobs.length === 0) { %>
            <p class="text-gray-400">You haven't posted any jobs yet.</p>
        <% } else { %>
            <% jobs.forEach(job => { %>
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 mb-4">
                    <h3 class="text-xl font-bold"><%= job.jobtitle %></h3>
                    <p class="text-gray-400"><%= job.companyname %></p>
                    <p class="text-gray-400"><%= job.mode %> — <%= job.location %></p>
                </div>
            <% }) %>
        <% } %>

    <% } else { %>
        <h2 class="text-xl font-semibold mb-4">Your Applications</h2>
        <% if (person.length === 0) { %>
            <p class="text-gray-400">You haven't applied to any jobs yet.</p>
        <% } else { %>
            <% person.forEach(application => { %>
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 mb-4">
                    <h3 class="text-xl font-bold"><%= application.job.jobtitle %></h3>
                    <p class="text-gray-400"><%= application.job.companyname %></p>
                    <span class="px-3 py-1 rounded-full text-sm mt-2 inline-block
                        <%= application.status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' :
                            application.status === 'accepted' ? 'bg-green-500/20 text-green-400' :
                            'bg-red-500/20 text-red-400' %>">
                        <%= application.status %>
                    </span>
                </div>
            <% }) %>
        <% } %>
    <% } %>

</body>
</html>

