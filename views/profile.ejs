<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Munus — Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/style/munus.css">
</head>
<body>

    <nav>
        <a href="/" class="nav-logo">Munus</a>
        <div class="nav-right">
            <% if (loggedInUsers.role === 'recruiter') { %>
                <a href="/dashboard" class="nav-btn btn-ghost"><i class="fas fa-th-large"></i> Dashboard</a>
            <% } else { %>
                <a href="/jobs" class="nav-btn btn-ghost"><i class="fas fa-briefcase"></i> Browse Jobs</a>
            <% } %>
            <a href="/logout" class="nav-btn btn-danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <main>
        <!-- Profile Card -->
        <div class="card" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 1.5rem;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--purple)); display: flex; align-items: center; justify-content: center; font-family: Syne, sans-serif; font-size: 1.5rem; font-weight: 700; flex-shrink: 0;">
                <%= loggedInUsers.username.charAt(0).toUpperCase() %>
            </div>
            <div style="flex: 1;">
                <h2 style="font-family: Syne, sans-serif; font-size: 1.3rem; font-weight: 700; letter-spacing: -0.3px;">
                    <%= loggedInUsers.username %>
                </h2>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.15rem;"><%= loggedInUsers.email %></p>
                <div style="margin-top: 0.5rem;">
                    <span class="badge <%= loggedInUsers.role === 'recruiter' ? 'badge-purple' : loggedInUsers.role === 'admin' ? 'badge-red' : 'badge-blue' %>">
                        <i class="fas <%= loggedInUsers.role === 'recruiter' ? 'fa-briefcase' : 'fa-search' %>" style="margin-right: 4px;"></i>
                        <%= loggedInUsers.role %>
                    </span>
                </div>
            </div>
        </div>

        <!-- Recruiter view -->
        <% if (loggedInUsers.role === 'recruiter') { %>
            <div class="page-tag" style="margin-bottom: 0.75rem;">Your Listings</div>
            <% if (jobs.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-briefcase"></i></div>
                    <p>No jobs posted yet. <a href="/postjobs">Post your first job →</a></p>
                </div>
            <% } else { %>
                <div class="grid-1">
                    <% jobs.forEach(job => { %>
                        <div class="card card-accent">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <h3 style="font-family: Syne, sans-serif; font-size: 1rem; font-weight: 700;">
                                        <%= job.jobtitle %>
                                    </h3>
                                    <p style="font-size: 0.82rem; color: var(--text-muted);"><%= job.companyname %></p>
                                </div>
                                <span class="badge <%= job.mode === 'Remote' ? 'badge-green' : job.mode === 'Hybrid' ? 'badge-purple' : 'badge-blue' %>">
                                    <%= job.mode %>
                                </span>
                            </div>
                            <div class="meta-row">
                                <div class="meta-item"><i class="fas fa-map-marker-alt"></i> <%= job.location %></div>
                                <div class="meta-item"><i class="fas fa-clock"></i> <%= new Date(job.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                            </div>
                            <div class="action-row">
                                <a href="/application/<%= job._id %>" class="nav-btn btn-success">
                                    <i class="fas fa-users"></i> Applications
                                </a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>

        <!-- User view -->
        <% } else { %>
            <div class="page-tag" style="margin-bottom: 0.75rem;">Your Applications</div>
            <% if (person.length === 0) { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-file-alt"></i></div>
                    <p>No applications yet. <a href="/jobs">Browse jobs →</a></p>
                </div>
            <% } else { %>
                <div class="grid-1">
                    <% person.forEach(application => { %>
                        <div class="card card-accent">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <h3 style="font-family: Syne, sans-serif; font-size: 1rem; font-weight: 700;">
                                        <%= application.job.jobtitle %>
                                    </h3>
                                    <p style="font-size: 0.82rem; color: var(--text-muted);"><%= application.job.companyname %></p>
                                </div>
                                <span class="badge <%= application.status === 'accepted' ? 'badge-green' : application.status === 'rejected' ? 'badge-red' : 'badge-yellow' %>">
                                    <%= application.status %>
                                </span>
                            </div>
                            <div class="meta-row">
                                <div class="meta-item"><i class="fas fa-calendar"></i> Applied <%= new Date(application.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                                <div class="meta-item"><i class="fas fa-clock"></i> Available immediately: <%= application.availability %></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        <% } %>
    </main>

</body>
</html>
