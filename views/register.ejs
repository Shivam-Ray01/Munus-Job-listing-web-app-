<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="w-full h-screen text-white flex items-center justify-center relative overflow-hidden">
<video class="absolute top-0 left-0 w-full h-full object-cover -z-10"
       src="/stockbg.mp4"
          autoplay 
        loop 
        muted 
        playsinline>
</video>

<!-- to put a black screen overlay that makes the video look good -->
 <div class="absolute inset-0 bg-black/40 -z-10"></div>

<div>
        <div class="p-10 text-white w-96 bg-transparent/10 backdrop-blur-lg rounded-2xl shadow-2xl border border-white/20">
   <h3 class="text-3xl mb-6 font-bold text-center tracking-wide">
            Create Account
        </h3>
        <form action="/register" method="post" class="flex flex-col items-center text-black">
              
            <input class="w-full px-3 py-2 bg-white border-white/10 rounded-lg placeholder-grey-500 outline-none mb-2" type="text" name="username" placeholder="Username" required>
              
              <input class="w-full px-3 py-2 bg-white border-white/10 rounded-lg placeholder-grey-500 outline-none mb-2" type="text" name="name" placeholder="Name">
              
              <input class="w-full px-3 py-2 bg-white border-white/10 rounded-lg placeholder-grey-500 outline-none mb-2" type="text" name="email" placeholder="email" required>
              
              <input class="w-full px-3 py-2 bg-white border-white/10 rounded-lg placeholder-grey-500 outline-none" type="text" name="password" placeholder="password" required>
              
              <select name="role" id="role"
                      class="w-full px-3 py-2 bg-white rounded-lg outline-none mb-2 text-gray-700 mt-2 cursor-pointer">
            <option value="role" disabled selected>Select Role</option>
               <option value="user">Job Seeker</option>
                 <option value="recruiter">Recruiter</option>
              </select>  
             
              <button type="submit" class="w-full px-3 py-2 bg-blue-500 rounded-lg mt-2">
                  Register    
                </button>
           
                <h4>Already have and account? <a class="text-blue-600 inline-block mt-3" href='/login'> <u>Login</u> </a> </h4>
                  <a class="text-white inline-block mt-3" href='/'> <u>Back to Homepage</u> </a>
        </form>
        </div>
    </div>
</body>
</html>
