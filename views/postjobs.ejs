<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post a Job</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen flex items-center justify-center p-10">

    <div class="w-full max-w-lg bg-gray-800 p-8 rounded-2xl border border-gray-700 shadow-2xl">
        <h2 class="text-2xl font-bold mb-6 text-center">Post a New Job</h2>

        <form action="/postjobs" method="post" class="flex flex-col gap-3">
            
            <input type="text" name="jobtitle" placeholder="Job Title" required
                class="px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400">

            <input type="text" name="companyname" placeholder="Company Name" required
                class="px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400">

            <select name="mode" class="px-4 py-2 rounded-lg bg-gray-700 text-gray-300 outline-none">
                <option value="Onsite">Onsite</option>
                <option value="Hybrid">Hybrid</option>
                <option value="Remote">Remote</option>
            </select>

            <input type="text" name="location" placeholder="Location" required
                class="px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400">

            <div class="flex gap-3">
                <input type="number" name="salary_min" placeholder="Min Salary" required
                    class="w-1/2 px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400">
                <input type="number" name="salary_max" placeholder="Max Salary" required
                    class="w-1/2 px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400">
            </div>

            <textarea name="description" placeholder="Job Description" rows="4" required
                class="px-4 py-2 rounded-lg bg-gray-700 outline-none placeholder-gray-400 resize-none"></textarea>

            <button type="submit"
                class="w-full py-2 bg-blue-500 hover:bg-blue-600 rounded-lg font-semibold transition duration-200">
                Post Job
            </button>

        </form>
    </div>

</body>
</html>