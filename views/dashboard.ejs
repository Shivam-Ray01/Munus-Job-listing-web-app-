<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Munus — Recruiter Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/style/munus.css">
</head>
<body>

    <nav>
        <a href="/" class="nav-logo">Munus</a>
        <div class="nav-right">
            <a href="/postjobs" class="nav-btn btn-grad">
                <i class="fas fa-plus"></i> Post a Job
            </a>
            <a href="/profile" class="nav-btn btn-ghost">
                <i class="fas fa-user"></i> Profile
            </a>
            <a href="/logout" class="nav-btn btn-danger">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </nav>

    <main>
        <div class="page-header">
            <div class="page-tag">Recruiter</div>
            <h1 class="page-title">Your <span>Dashboard</span></h1>
            <p class="page-sub">Manage your job listings and review applications</p>
        </div>

        <% if (jobs.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-briefcase"></i></div>
                <p>You haven't posted any jobs yet.</p>
                <a href="/postjobs" style="display:inline-block; margin-top: 0.75rem;">Post your first job →</a>
            </div>
        <% } else { %>
            <div class="grid-1">
                <% jobs.forEach(job => { %>
                    <div class="card card-accent">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                            <div>
                                <h3 style="font-family: Syne, sans-serif; font-size: 1.1rem; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 0.2rem;">
                                    <%= job.jobtitle %>
                                </h3>
                                <p style="font-size: 0.85rem; color: var(--text-muted);"><%= job.companyname %></p>
                            </div>
                            <span class="badge <%= job.mode === 'Remote' ? 'badge-green' : job.mode === 'Hybrid' ? 'badge-purple' : 'badge-blue' %>">
                                <%= job.mode %>
                            </span>
                        </div>

                        <div class="meta-row">
                            <div class="meta-item"><i class="fas fa-map-marker-alt"></i> <%= job.location %></div>
                            <div class="meta-item"><i class="fas fa-rupee-sign"></i> <%= job.salary.min.toLocaleString() %> – <%= job.salary.max.toLocaleString() %></div>
                            <div class="meta-item"><i class="fas fa-clock"></i> Posted <%= new Date(job.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                        </div>

                        <p style="margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            <%= job.description %>
                        </p>

                        <div class="action-row">
                            <a href="/application/<%= job._id %>" class="nav-btn btn-success">
                                <i class="fas fa-users"></i> View Applications
                            </a>
                            <form action="/editjob/<%= job._id %>" method="get" style="display:inline;">
                                <button type="submit" class="nav-btn btn-warn">
                                    <i class="fas fa-pen"></i> Edit
                                </button>
                            </form>
                            <form action="/delete" method="post" style="display:inline;">
                                <input type="hidden" name="postid" value="<%= job._id %>">
                                <button type="submit" class="nav-btn btn-danger">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

</body>
</html>
