<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jobs</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 text-white min-h-screen p-10">

    <div class="flex justify-between items-center mb-10">
        <h1 class="text-3xl font-bold">Available Jobs</h1>
        <a href="/profile"
           class="bg-gray-700 px-4 py-2 rounded-lg hover:bg-gray-600 transition duration-200">
            My Profile
        </a>
    </div>

    <% if (jobs.length === 0) { %>
        <div class="bg-gray-800 p-6 rounded-xl text-center text-gray-400 border border-gray-700">
            <p>No jobs posted yet. Check back later!</p>
        </div>
    <% } else { %>
        <div class="grid grid-cols-1 gap-4">
            <% jobs.forEach(job => { %>
                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 hover:border-blue-500 transition duration-200">
                    
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-xl font-bold"><%= job.jobtitle %></h3>
                            <p class="text-gray-400"><%= job.companyname %></p>
                </div>
                        <span class="bg-blue-500/20 text-blue-400 px-3 py-1 rounded-full text-sm">
                  <%= job.mode %>
         </span>
                    </div>

                    <div class="mt-3 flex gap-4 text-sm text-gray-400">
                        <p>📍 <%= job.location %></p>
                        <p>💰 ₹<%= job.salary.min %> - ₹<%= job.salary.max %></p>
                    </div>

            <p class="mt-3 text-gray-300 text-sm"><%= job.description %></p>
                
                    <div class="mt-4">
                 <form action="/apply/<%= job._id %>" method="post">
                            <button type="submit"
                    class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg text-sm font-semibold transition duration-200">
                                Apply Now
               </button>
           </form>
       </div>
  </div>
   <% }) %>
          </div>
    <% } %>

</body>
</html>